<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="WarehouseController.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:WarehouseController"
    Title="WarehouseController">

    <ShellContent
        Title="Dashboard"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
    <ShellContent
        Title="Products"
        ContentTemplate="{DataTemplate local:ProductsPage}"
        Route="ProductsPage" />
    <!--<ShellContent
        Route="AddProductPage"
        ContentTemplate="{DataTemplate views:AddProductPage}"
        IsVisible="False" />-->
    <ShellContent
     Title="Warehouses"
     ContentTemplate="{DataTemplate local:WarehousePage}"
     Route="WarehousePage" />

</Shell>
