<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WarehouseController.View.UserView.AddUserPage"
             xmlns:vm="clr-namespace:WarehouseController.ViewModel.UserVM;assembly=WarehouseController"
             x:DataType="vm:AddUserViewModel"
             Shell.PresentationMode="Animated"
             Title="{Binding Title}">
    <VerticalStackLayout>
        <Label Text="Login" />
            <Entry Text="{Binding Login, Mode=TwoWay}" Placeholder="Login" />

            <Label Text="Hasło" />
            <Entry Text="{Binding Password, Mode=TwoWay}" Placeholder="Hasło" IsPassword="True" />

            <Label Text="Rola" />
            <Entry Text="{Binding Role, Mode=TwoWay}" Placeholder="Rola" />
        <HorizontalStackLayout Spacing="30" Margin="10">
            <ImageButton   
                    Source="save.png"  
                    Command="{Binding SaveCommand}"/>
            <ImageButton   
                    Source="cancel.png"  
                    Command="{Binding CancelCommand}"/>
        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentPage>