<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WarehouseController.View.UserView.DetailUserPage"
             xmlns:vm="clr-namespace:WarehouseController.ViewModel.UserVM"
             x:DataType="vm:DetailUserViewModel"
             Title="{Binding Title}"
             Shell.PresentationMode="Animated">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">
            <Label Text="User ID" FontSize="14" />
            <Label Text="{Binding Id}" FontSize="14" />

            <Label Text="Username" FontSize="14" />
            <Label Text="{Binding Login}" FontSize="14" />

            <Label Text="Role" FontSize="14" />
            <Label Text="{Binding Role}" FontSize="14" />

            <HorizontalStackLayout Spacing="30" Margin="10">
                <ImageButton 
                     Source="edit.png"
                     Command="{Binding UpdateCommand}" />

                <ImageButton  
                     Source="remove.png"
                     Command="{Binding DeleteCommand}" />

                <ImageButton  
                     Source="cancel.png"
                     Command="{Binding CancelCommand}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
