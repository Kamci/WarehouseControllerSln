<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WarehouseController.View.SupplierView.EditSupplierPage"
              Title="Edit Supplier"
             xmlns:vm="clr-namespace:WarehouseController.ViewModel.SupplierVM"
             x:DataType="vm:EditSupplierViewModel"
             Shell.PresentationMode="Animated">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">
            <Label Text="Id" FontSize="14" />
            <Label Text="{Binding Id, Mode=TwoWay, Converter={StaticResource IntToStringConverter}}" FontSize="14" />
            <Label Text="Name" FontSize="14" />
            <Editor Text="{Binding Name, Mode=TwoWay}" FontSize="14"/>
            <Label Text="Contact" FontSize="14" />
            <Editor Text="{Binding Contact, Mode=TwoWay}" FontSize="14"/>
            <HorizontalStackLayout Spacing="30" Margin="10">
                <ImageButton   
                      Source="save.png"  
                      Command="{Binding SaveCommand}"/>
                        <ImageButton   
                      Source="cancel.png"  
                      Command="{Binding CancelCommand}"/>   
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>