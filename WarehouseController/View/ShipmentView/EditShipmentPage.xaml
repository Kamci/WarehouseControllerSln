<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WarehouseController.View.ShipmentView.EditShipmentPage"
             xmlns:vm="clr-namespace:WarehouseController.ViewModel.ShipmentVM;assembly=WarehouseController"
            x:DataType="vm:EditShipmentViewModel"
            Shell.PresentationMode="Animated"
         Title="Add Shipment">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">
            <Label Text="Id" FontSize="14" />
            <Label Text="{Binding Id, Mode=TwoWay, Converter={StaticResource IntToStringConverter}}" FontSize="14" />
            <Picker Title="Select Warehouse"
              ItemsSource="{Binding Warehouses}"
              ItemDisplayBinding="{Binding Name}"
              SelectedItem="{Binding SelectedWarehouse}" />
            <Picker Title="Select Supplier"
              ItemsSource="{Binding Suppliers}"
              ItemDisplayBinding="{Binding Name}"
              SelectedItem="{Binding SelectedSupplier}" />
            <Label Text="Shipment Date" FontSize="14" />
            <DatePicker Date="{Binding ShipmentDate}"  IsEnabled="True" IsVisible="True" FontSize="14" />
            <Label Text="Order Status" />
            <Picker Title="Select Status"
                    ItemsSource="{Binding Statuses}"
                    SelectedItem="{Binding SelectedStatus}" />  
            <HorizontalStackLayout Spacing="30" Margin="10">
                <ImageButton   
       Source="save.png"  
       Command="{Binding SaveCommand}"/>
                <ImageButton   
       Source="cancel.png"  
       Command="{Binding CancelCommand}"/>
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>